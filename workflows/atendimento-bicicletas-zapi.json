            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "transferencia",
              "leftValue": "={{ $json.resposta }}",
              "rightValue": "[TRANSFERIR_ATENDIMENTO]",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "verificar-transferencia",
      "name": "Verificar transferência",
