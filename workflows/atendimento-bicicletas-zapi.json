              "name": "Client-Token",
              "value": "={{ $env.ZAPI_CLIENT_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { phone: $json.telefone, message: $json.resposta } }}",
        "options": {}
      },
      "id": "zapi-enviar-resposta",
      "name": "Z-API - Enviar resposta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
