        "method": "POST",
        "url": "={{ ($env.ZAPI_BASE_URL || 'https://api.z-api.io') + '/instances/' + $env.ZAPI_INSTANCE_ID + '/token/' + $env.ZAPI_TOKEN + '/send-text' }}",
        "sendHeaders": true,
        "headerParameters": {
