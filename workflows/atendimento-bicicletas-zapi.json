        -460,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const mensagem = $json.mensagem || '';\\nconst nome = $json.nome || 'Cliente';\\n\\nconst regras = `Você é um atendente virtual de um negócio de aluguel, manutenção e venda de bicicletas.\\nPrioridade: aluguel de bicicleta, manutenção e venda.\\nResponda de forma curta, natural e objetiva.\\nUse o histórico e a memória quando disponíveis.\\nNão solicite dados técnicos internos, tokens, QR Code ou API Keys.\\nQuando não conseguir responder, quando o cliente pedir humano, ou quando for reclamação complexa, retorne exatamente: [TRANSFERIR_ATENDIMENTO]\\nNão use Markdown, JSON ou blocos de código.`;\\n\\nreturn [{ json: { ...$json, contexto_agente: regras, entrada_usuario: `${nome}: ${mensagem}` } }];"
      },
      "id": "preparar-contexto",
      "name": "Preparar contexto do atendimento",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -220,
        -120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.OPENROUTER_API_URL || 'https://openrouter.ai/api/v1/chat/completions' }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: $env.OPENROUTER_MODEL || 'openai/gpt-4o-mini', messages: [ { role: 'system', content: $json.contexto_agente }, { role: 'user', content: $json.entrada_usuario } ] } }}",
        "options": {}
      },
      "id": "openrouter",
      "name": "OpenRouter - Gerar resposta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        40,
        -120
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "CONFIGURAR_NO_N8N",
          "name": "OpenRouter Header Auth"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "resposta",
              "name": "resposta",
              "value": "={{ $json.choices?.[0]?.message?.content || '[TRANSFERIR_ATENDIMENTO]' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "extrair-resposta",
      "name": "Extrair resposta",
